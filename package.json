{
  "name": "pi-packages",
  "version": "2.1.0",
  "private": true,
  "description": "Extensions for pi, the AI coding agent",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "check": "npm run lint && npm run typecheck",
    "check:ci": "biome ci . && tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "audit:workspaces": "./scripts/audit-workspaces.sh",
    "ci:detect": "./scripts/detect-ci-packages.sh"
  },
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "pi",
    "pi-package",
    "pi-packages",
    "pi-extensions",
    "pi-coding-agent",
    "extensions",
    "ai"
  ],
  "pi": {
    "extensions": [
      "./packages/pi-notion/extensions/index.ts",
      "./packages/pi-notion/extensions/mcp-client.ts"
    ],
    "skills": [
      "./packages/pi-notion/skills"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.5",
    "@mariozechner/pi-ai": "^0.69.0",
    "@mariozechner/pi-coding-agent": "^0.69.0",
    "typebox": "^1.0.0",
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^4.1.2",
    "typescript": "^5.5.0",
    "vitest": "^4.0.18"
  },
  "license": "MIT",
  "overrides": {
    "fast-xml-parser": "^5.7.0",
    "uuid": "^14.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
