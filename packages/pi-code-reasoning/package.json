{
  "name": "@feniix/pi-code-reasoning",
  "version": "5.0.0",
  "description": "Code Reasoning tools for pi and MCP — reflective sequential thinking with branching and revision support",
  "keywords": [
    "pi",
    "pi-package",
    "pi-extension",
    "pi-coding-agent",
    "ai",
    "code-reasoning",
    "sequential-thinking",
    "branching",
    "revision",
    "problem-solving",
    "mcp",
    "model-context-protocol",
    "bridgekit",
    "portable-tools"
  ],
  "type": "module",
  "files": [
    "bin/",
    "extensions/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./extensions/index.ts"
    ]
  },
  "exports": {
    "./mcp": {
      "types": "./dist/extensions/mcp-server.d.ts",
      "import": "./dist/extensions/mcp-server.js"
    },
    "./tools": {
      "types": "./dist/extensions/tools.d.ts",
      "import": "./dist/extensions/tools.js"
    },
    "./package.json": "./package.json",
    "./extensions/*.js": {
      "types": "./dist/extensions/*.d.ts",
      "import": "./dist/extensions/*.js"
    },
    "./extensions/*": {
      "types": "./dist/extensions/*.d.ts",
      "import": "./dist/extensions/*.js"
    }
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "dependencies": {
    "@feniix/bridgekit": "^0.13.0",
    "typebox": "^1.1.31"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/feniix/pi-extensions.git",
    "directory": "packages/pi-code-reasoning"
  },
  "author": {
    "name": "Sebastian Otaegui",
    "url": "https://github.com/feniix"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/feniix/pi-extensions/issues"
  },
  "homepage": "https://github.com/feniix/pi-extensions/tree/main/packages/pi-code-reasoning#readme",
  "peerDependenciesMeta": {
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  },
  "bin": {
    "pi-code-reasoning": "./bin/pi-code-reasoning.js"
  },
  "scripts": {
    "build:mcp": "tsc --project tsconfig.mcp.json && node -e \"require('node:fs').chmodSync('dist/extensions/mcp-server.js', 0o755)\"",
    "prepack": "npm run build:mcp"
  }
}
