{
  "name": "@feniix/pi-exa",
  "version": "5.0.1",
  "description": "Exa API extension for pi — web search, content fetching, and advanced search via Exa AI",
  "keywords": [
    "pi",
    "pi-package",
    "pi-extension",
    "pi-coding-agent",
    "ai",
    "exa",
    "search",
    "websearch"
  ],
  "type": "module",
  "files": [
    "bin/",
    "dist/",
    "extensions/",
    "skills/",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./extensions/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "bin": {
    "pi-exa": "./bin/pi-exa.js"
  },
  "exports": {
    ".": {
      "types": "./dist/extensions/tools.d.ts",
      "import": "./dist/extensions/tools.js"
    },
    "./mcp": {
      "types": "./dist/extensions/mcp-server.d.ts",
      "import": "./dist/extensions/mcp-server.js"
    },
    "./tools": {
      "types": "./dist/extensions/tools.d.ts",
      "import": "./dist/extensions/tools.js"
    },
    "./package.json": "./package.json",
    "./extensions/*.js": {
      "types": "./dist/extensions/*.d.ts",
      "import": "./dist/extensions/*.js"
    },
    "./extensions/*": {
      "types": "./dist/extensions/*.d.ts",
      "import": "./dist/extensions/*.js"
    }
  },
  "scripts": {
    "build:mcp": "tsc --project tsconfig.mcp.json && node -e \"require('node:fs').chmodSync('dist/extensions/mcp-server.js', 0o755)\"",
    "prepack": "npm run build:mcp"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "dependencies": {
    "@feniix/bridgekit": "^0.13.0",
    "exa-js": "^2.8.0",
    "typebox": "^1.1.31"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/feniix/pi-extensions.git",
    "directory": "packages/pi-exa"
  },
  "author": {
    "name": "Sebastian Otaegui",
    "url": "https://github.com/feniix"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/feniix/pi-extensions/issues"
  },
  "homepage": "https://github.com/feniix/pi-extensions/tree/main/packages/pi-exa#readme",
  "peerDependenciesMeta": {
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  }
}
