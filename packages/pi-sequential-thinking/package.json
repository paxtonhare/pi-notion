{
  "name": "@feniix/pi-sequential-thinking",
  "version": "5.0.2",
  "description": "Sequential Thinking extension for pi — structured progressive thinking through defined stages, also runnable as an MCP stdio server",
  "keywords": [
    "pi",
    "pi-package",
    "pi-extension",
    "pi-coding-agent",
    "ai",
    "sequential-thinking",
    "mcp",
    "model-context-protocol",
    "structured-thinking",
    "bridgekit"
  ],
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "files": [
    "bin/",
    "dist/",
    "extensions/",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./extensions/index.ts"
    ]
  },
  "bin": {
    "pi-sequential-thinking-mcp": "./bin/pi-sequential-thinking-mcp.js"
  },
  "scripts": {
    "build:mcp": "tsc --project tsconfig.mcp.json && chmod +x dist/extensions/mcp-server.js",
    "prepack": "npm run build:mcp"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/feniix/pi-extensions.git",
    "directory": "packages/pi-sequential-thinking"
  },
  "author": {
    "name": "Sebastian Otaegui",
    "url": "https://github.com/feniix"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/feniix/pi-extensions/issues"
  },
  "homepage": "https://github.com/feniix/pi-extensions/tree/main/packages/pi-sequential-thinking#readme",
  "peerDependenciesMeta": {
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  },
  "dependencies": {
    "@feniix/bridgekit": "^0.13.0",
    "typebox": "^1.1.31"
  }
}
